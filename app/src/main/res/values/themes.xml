<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Greentify" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary branding color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/colorBackground</item>
        <item name="android:fontFamily">@font/adlam_display</item>

        <!-- Secondary (accent) -->
        <item name="colorSecondary">@color/colorAccent</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorBackground</item>
        <item name="colorOnSurface">@color/colorText</item>

        <!-- Button and text color -->
        <item name="android:textColor">@color/colorText</item>
        <item name="android:buttonStyle">@style/GreentifyButton</item>

    </style>
</resources>
