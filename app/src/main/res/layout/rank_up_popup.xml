<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:elevation="8dp"
    android:padding="20dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/rankUpTitle"
            android:text="Congratulations!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/nav_item_color2"
            android:layout_marginBottom="12dp"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <TextView
            android:id="@+id/rankUpMessage"
            android:text="You have ranked up in the leaderboard!"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/rankUpAnimation"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:lottie_loop="true"
            app:lottie_autoPlay="true" />

        <TextView
            android:id="@+id/rankChangeText"
            android:text="Old Rank: X → New Rank: Y"
            android:textSize="14sp"
            android:textColor="#000000"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"/>

        <Button
            android:id="@+id/closePopup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/nav_item_color2"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
