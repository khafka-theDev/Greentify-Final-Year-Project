<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- App Logo -->
    <com.google.android.material.imageview.ShapeableImageView
        android:layout_width="194dp"
        android:layout_height="181dp"
        android:layout_marginBottom="24dp"
        android:adjustViewBounds="true"
        android:contentDescription="Greentify Logo"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_logo"
        app:shapeAppearanceOverlay="@style/RoundedImageShape" />

    <!-- Title Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="With Greentify, you can:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="12dp" />

    <!-- Features List -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="- Recycle 5 types of waste\n- Add friends\n- Compete globally\n- Grow your profile with rewards"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Don't show again checkbox -->
    <CheckBox
        android:id="@+id/checkboxDontShowAgain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don’t show this again"
        android:textColor="@android:color/black"
        android:layout_marginBottom="24dp" />

    <!-- Register button -->
    <Button
        android:id="@+id/btnRegisterNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Register Now"
        android:backgroundTint="@color/nav_item_color2"
        android:textColor="@android:color/white" />
</LinearLayout>
