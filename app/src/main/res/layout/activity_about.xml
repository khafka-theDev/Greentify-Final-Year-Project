<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:divider="@android:color/transparent"
        android:showDividers="middle">

        <!-- Header -->
        <TextView
            android:text="Welcome to Greentify!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/nav_item_color2"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Greentify is your companion in promoting recycling habits, earning points, and growing your digital tree. Here's how to make the most of it:"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Reusable Section Template -->
        <!-- Each section starts here -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="♻️ How to Recycle"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/recycle_section"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Go to the homepage and tap on a material (Paper, Plastic, Glass, etc.). Select a nearby recycling location using the map, take a picture, enter the weight, and submit."
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Repeat for each section below -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="🏆 Earning Points and Green Credits"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/earn_section"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Each recycling activity earns you points and Green Credits based on the weight and material. These help you climb the leaderboard and claim rewards!"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="🌱 Tracking Your Tree Growth"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/tree_section"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Your profile shows a growing tree for each material type. As you recycle more, the tree progresses through levels like seedling, sprout, and full tree!"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="📊 Viewing the Leaderboard"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/leaderboard_section"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Check your global rank and compare yourself with others. Rank up to unlock new badge levels and animations."
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="👥 Friend System"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/friends"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Add friends, accept requests, and view their profiles. Compete with them on the leaderboard and compare tree growth progress."
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/about_section_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="📦 Claiming Rewards"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/reward_section"
                app:lottie_autoPlay="true"
                app:lottie_loop="true" />

            <TextView
                android:text="Use your Green Credits to claim rewards. After submitting, you’ll see an animation and your credits will update."
                android:textSize="15sp"
                android:textColor="@color/black"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Footer -->
        <Button
            android:id="@+id/buttonFinishAbout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finish"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white" />

        <TextView
            android:text="App Version: 1.0.0"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Contact: greentify.support@gmail.com"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>
