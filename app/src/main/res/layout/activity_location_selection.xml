<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map Fragment -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fontFamily="@font/adlam_display"/>

    <!-- Overlay Title -->
    <TextView
        android:id="@+id/overlayTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:background="#AA000000"
        android:padding="8dp"
        android:text="Select a location to recycle"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/transparent"
        android:textSize="16sp"
        android:textStyle="bold"
        android:elevation="6dp"/>

    <!-- Location Details Bottom Panel -->
    <LinearLayout
        android:id="@+id/locationDetailsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CCFFFFFF"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="8dp">

        <TextView
            android:id="@+id/locationName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <ImageView
            android:id="@+id/locationImageView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerCrop"
            android:contentDescription="Recycling Center Image" />

        <Button
            android:id="@+id/chooseLocationButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Choose This Location"
            android:textColor="@android:color/white"
            android:background="@drawable/rounded_button" />
    </LinearLayout>

</FrameLayout>
