<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nav_item_color2"
    tools:context=".Rewards.RewardsActivity">

    <!-- App Title -->
    <TextView
        android:id="@+id/rewardsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rewards"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/darkGreen"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Green Wallet -->
    <androidx.cardview.widget.CardView
        android:id="@+id/greenWalletCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/rewardsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/white"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_wallet"
                android:contentDescription="Wallet" />

            <TextView
                android:id="@+id/greenWalletText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Green Wallet: 0"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:layout_marginStart="12dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- View Claimed Rewards Button -->
    <Button
        android:id="@+id/buttonViewClaimedRewards"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Claimed Rewards"
        android:layout_marginTop="12dp"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/darkGreen"
        app:layout_constraintTop_toBottomOf="@id/greenWalletCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Rewards List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewRewards"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/buttonViewClaimedRewards"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress Spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/recyclerViewRewards"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewRewards"
        app:layout_constraintStart_toStartOf="@id/recyclerViewRewards"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewRewards" />

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="0dp"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item_color2"
        app:itemTextColor="@color/nav_item_color2"
        app:itemRippleColor="@color/nav_ripple_color"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
