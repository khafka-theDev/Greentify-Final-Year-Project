<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/rounded_card"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <ImageView
        android:id="@+id/acceptedFriendProfilePic"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_profile"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_round_white"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/acceptedFriendUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Friend Username"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <!-- Optional email display -->
        <!--
        <TextView
            android:id="@+id/acceptedFriendEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="friend@example.com"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray" />
        -->
    </LinearLayout>

    <Button
        android:id="@+id/btnViewProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Profile"
        android:backgroundTint="@color/nav_item_color2"
        android:textColor="@android:color/white" />
</LinearLayout>
