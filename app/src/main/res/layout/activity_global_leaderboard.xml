<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header Banner (optional, like season countdown) -->
    <!-- Header Banner with Overlaid Text -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp">

        <ImageView
            android:id="@+id/arenaBanner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/arena_banner" />

        <TextView
            android:id="@+id/bannerMessage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Start recycling to join the leaderboard now!"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@android:color/transparent"
            android:padding="16dp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="2" />
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/globalTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Global Leaderboard"
        android:textColor="@android:color/black"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingVertical="12dp" />

    <!-- RecyclerView for leaderboard -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/globalRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false" />

    <!-- User's Own Rank at the bottom fixed -->
    <LinearLayout
        android:id="@+id/userRankContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#EEF1F6"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/userAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_profile"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_round_white" />

        <TextView
            android:id="@+id/userRankText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="You are in Rank: 0"
            android:textSize="16sp"
            android:textColor="@android:color/black" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/star_container"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_star" />

            <TextView
                android:id="@+id/userPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:layout_marginStart="4dp"
                android:textColor="@android:color/black" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@color/nav_item_color2"
        app:itemTextColor="@color/nav_item_color2"
        app:itemRippleColor="@color/nav_ripple_color"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>