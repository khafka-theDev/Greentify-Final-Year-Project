<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <!-- Content area with scroll -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:background="@android:color/transparent">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_white_transparent"
                android:padding="20dp"
                android:elevation="6dp">

                <!-- Image with soft corners -->
                <ImageView
                    android:id="@+id/rewardDetailImage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/reward_image_desc"
                    android:background="@drawable/rounded_card"
                    android:clipToOutline="true" />

                <!-- Reward Name -->
                <TextView
                    android:id="@+id/rewardDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎁 Reward Name"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp" />

                <!-- Reward Cost -->
                <TextView
                    android:id="@+id/rewardDetailCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪙 50 Points"
                    android:textSize="16sp"
                    android:textColor="#5D9CEC"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />

                <!-- Description -->
                <TextView
                    android:id="@+id/rewardDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✨ A special gift for your effort!"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:layout_marginTop="12dp" />

                <!-- Expiry -->
                <TextView
                    android:id="@+id/rewardDetailExpiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳ Valid until: 2025-12-31"
                    android:textSize="14sp"
                    android:textColor="#888888"
                    android:layout_marginTop="16dp" />

                <!-- Stock -->
                <TextView
                    android:id="@+id/rewardDetailStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 In Stock"
                    android:textSize="14sp"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="6dp"
                    android:textStyle="bold" />

                <!-- Claim Button -->
                <Button
                    android:id="@+id/claimRewardButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎉 Claim Reward"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:backgroundTint="@color/nav_item_color2"
                    android:layout_marginTop="24dp"
                    android:padding="12dp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- Bottom Navigation View fixed at bottom -->
</LinearLayout>
