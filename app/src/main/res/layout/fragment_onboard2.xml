<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="194dp"
            android:layout_height="181dp"
            android:layout_marginBottom="24dp"
            android:adjustViewBounds="true"
            android:contentDescription="Greentify Logo"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_logo"
            app:shapeAppearanceOverlay="@style/RoundedImageShape" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Greentify helps you become a hero by taking small green actions.\n\nRecycle waste, earn points, and help protect the Earth while unlocking rewards."
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"
            app:backgroundTint="@color/nav_item_color2" />
    </LinearLayout>
</ScrollView>
