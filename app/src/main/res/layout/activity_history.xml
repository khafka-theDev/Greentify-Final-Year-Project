<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/colorBackground">

    <!-- Page Title -->
    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Recycling History"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Optional subtitle -->
    <TextView
        android:id="@+id/textViewSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your recent recycling submissions"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textViewTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Filter buttons row -->
    <LinearLayout
        android:id="@+id/filterButtonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textViewSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnFilterAll"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:text="All"
            android:textSize="10sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="12sp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterPending"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:text="Pending"
            android:textSize="10sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="12sp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterAccepted"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:text="Approved"
            android:textSize="10sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="12sp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnFilterRejected"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:text="Rejected"
            android:textSize="10sp"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="8sp"
            android:autoSizeMaxTextSize="12sp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white"/>
    </LinearLayout>


    <!-- RecyclerView for recycling history -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewHistory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/filterButtonLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <!-- Empty state text -->
    <TextView
        android:id="@+id/textNoHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No recycling history available."
        android:textSize="16sp"
        android:textColor="@color/black"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterButtonLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
