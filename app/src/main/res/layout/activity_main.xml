<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Main content area with FrameLayout to stack scroll + bottom nav -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="top"
            android:layout_marginBottom="56dp"
        android:fillViewport="true"
        android:background="@color/colorBackground">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/mainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorBackground">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:background="@color/nav_item_color2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/hamburgerMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:clickable="true"
                android:contentDescription="Menu"
                android:focusable="true"
                android:src="@drawable/ic_menu" />

            <ImageView
                android:id="@+id/notificationButton"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:clickable="true"
                android:contentDescription="Notifications"
                android:focusable="true"
                android:src="@drawable/noti_kosong" />
        </RelativeLayout>

        <!-- Extended Cyan Background -->
            <View
                android:id="@+id/extendedCyanBg"
                android:layout_width="match_parent"
                android:layout_height="169dp"
                android:background="@drawable/rounded_cyan_bg"
                app:layout_constraintDimensionRatio="H,1:3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerLayout" />


        <!-- Welcome User -->
        <LinearLayout
            android:id="@+id/welcomeUserLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <ImageView
                android:id="@+id/profileImageView"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_round_white"
                android:contentDescription="Profile Image"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile" />

            <TextView
                android:id="@+id/welcomeUserText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/adlam_display"
                android:text="Welcome, User!"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Wallet Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/userInfoCard"
            android:layout_width="299dp"
            android:layout_height="62dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#80FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/welcomeUserLayout">

            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/userCreditsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/adlam_display"
                    android:text="Green Wallet: 0"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Material Buttons -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/white"
                android:padding="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/userInfoCard">

                <LinearLayout
                    android:layout_width="287dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Instruction Text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:gravity="center"
                        android:text="Select one material to recycle"
                        android:textColor="@color/black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- Paper -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageButton
                                android:id="@+id/buttonPaper"
                                android:layout_width="80dp"
                                android:layout_height="60dp"
                                android:contentDescription="Paper"
                                android:padding="8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_paper" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Paper"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Plastic -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageButton
                                android:id="@+id/buttonPlastic"
                                android:layout_width="80dp"
                                android:layout_height="60dp"
                                android:contentDescription="Paper"
                                android:padding="8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_plastic" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Plastic"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Glass -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageButton
                                android:id="@+id/buttonGlass"
                                android:layout_width="80dp"
                                android:layout_height="60dp"
                                android:contentDescription="Paper"
                                android:padding="8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_glass" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Glass"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <!-- Metal -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageButton
                                android:id="@+id/buttonMetal"
                                android:layout_width="80dp"
                                android:layout_height="60dp"
                                android:contentDescription="Metal"
                                android:padding="8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_metal" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="Metal"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <!-- E waste -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageButton
                                android:id="@+id/buttonEWaste"
                                android:layout_width="80dp"
                                android:layout_height="60dp"
                                android:contentDescription="E-waste"
                                android:padding="8dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/ic_ewaste" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="E-Waste"
                                android:textColor="@color/black"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        <!-- carouselLabel -->
        <TextView
            android:id="@+id/carouselLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="Check out the latest reward!"
            android:textColor="@color/darkGreen"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardContainer"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- carouselCard (ViewPager2 wrapper) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/carouselCard"
            android:layout_width="382dp"
            android:layout_height="240dp"
            android:layout_marginTop="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="@android:color/white"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/carouselLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/rewardCarousel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/white"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="20dp"
                android:overScrollMode="never" />
        </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
        <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="0dp"
        app:itemIconTint="@color/nav_item_color2"
        app:itemRippleColor="@color/nav_ripple_color"
        app:itemTextColor="@color/nav_item_color2"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />
</FrameLayout>
    <!-- Side Drawer -->
        <LinearLayout
            android:id="@+id/sideDrawer"
            android:layout_width="280dp"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:background="@color/nav_item_color2"
            android:padding="20dp"
            android:divider="?android:attr/dividerHorizontal"
            android:showDividers="middle">

            <!-- User Info Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="#80FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Profile Image -->
                    <ImageView
                        android:id="@+id/drawerProfileImage"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_profile"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_round_white"
                        android:layout_marginEnd="12dp" />

                    <!-- Name, then Points + Wallet below -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Username -->
                        <TextView
                            android:id="@+id/drawerUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤 User"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="@android:color/black" />

                        <!-- Points -->
                        <TextView
                            android:id="@+id/drawerPoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Points: 0"
                            android:textSize="14sp"
                            android:textColor="@android:color/black"
                            android:layout_marginTop="6dp" />

                        <!-- Wallet -->
                        <TextView
                            android:id="@+id/drawerWallet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 Wallet: 0"
                            android:textSize="14sp"
                            android:textColor="@android:color/black"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <!-- New Navigation Buttons -->
            <Button
                android:id="@+id/buttonProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Profile"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏆 Leaderboard"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonReward"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎁 Reward"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonFriendList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 Friend List"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/buttonAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ About"
                android:backgroundTint="#80FFFFFF"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <!-- Spacer to push logout to the bottom -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Logout -->
            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚪 Logout"
                android:textColor="@android:color/white"
                android:backgroundTint="@android:color/holo_red_dark"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </androidx.drawerlayout.widget.DrawerLayout>
