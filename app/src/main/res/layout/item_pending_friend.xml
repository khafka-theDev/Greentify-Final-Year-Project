<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/rounded_card"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <!-- Profile Picture -->
    <ImageView
        android:id="@+id/pendingFriendProfilePic"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_profile"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_round_white"
        android:scaleType="centerCrop" />

    <!-- Username and Email -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1">

        <TextView
            android:id="@+id/pendingFriendUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Friend Username"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <TextView
            android:id="@+id/pendingFriendEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="friend@example.com"
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Accept/Reject Buttons (only for received requests) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accept"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/nav_item_color2"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnReject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reject"
            android:textSize="14sp"
            android:backgroundTint="@android:color/holo_red_light"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- "Requested" status (only for sent requests) -->
    <TextView
        android:id="@+id/statusRequested"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Requested"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/nav_item_color2"
        android:visibility="gone"
        android:paddingStart="12dp" />
</LinearLayout>
